    kcu.constraint_name,
    kcu.column_name AS from_column,
    ukcu.table_catalog AS to_catalog,
    ukcu.table_schema AS to_schema,
    ukcu.table_name AS to_table,
    ukcu.column_name AS to_column
  FROM `ecommerce`.information_schema.key_column_usage kcu
  JOIN `ecommerce`.information_schema.referential_constraints rc
    ON kcu.constraint_name = rc.constraint_name
  JOIN `ecommerce`.information_schema.key_column_usage ukcu
    ON rc.unique_constraint_name = ukcu.constraint_name
    AND kcu.ordinal_position = ukcu.ordinal_position
  WHERE kcu.table_catalog = 'ecommerce'
    AND kcu.table_schema = 'dev_intermediate_test'
    AND kcu.table_name = 'int_review_classify'
    AND kcu.constraint_name IN (
