        create or replace table `ecommerce`.`default_mart_test`.`fact_review`
      
      
    using delta
  
      
      
      CLUSTER BY (ts_review_answer)
      
      
      comment 'Tabela final de análises (reviews), combinando dados de staging com classificação de sentimento e categoria geradas em modelos intermediários.
'
      
    tblproperties ('delta.autoOptimize.optimizeWrite' = 'true' , 'delta.autoOptimize.autoCompact' = 'true' 
    )
      as
      SELECT
    id_review,
    id_order,
    nu_review_score,
    ts_review_answer,
    nm_review_title,
    nm_review_message,
    in_has_comment,
    st.sentiment_label,
    ct.category_label
FROM 
    `ecommerce`.`default_staging_test`.`stg_review` AS av
LEFT JOIN 
    `ecommerce`.`default_intermediate_test`.`int_review_classify` AS ct 
    USING (id_review, id_order, ts_review_answer)
LEFT JOIN 
    `ecommerce`.`default_intermediate_test`.`int_review_sentiment` AS st
    USING (id_review, id_order, ts_review_answer)
  
