    WHERE 
        in_has_comment IS TRUE
        AND ts_review_answer IS NOT NULL
)
SELECT
    id_review,
    id_order,
    ts_review_answer,
    AI_ANALYZE_SENTIMENT(nm_review_message)  AS sentiment_label
FROM
    base
  
